# Public form endpoint (Google Apps Script Web App URL — Refer-a-Cause + Contact submit here)
NEXT_PUBLIC_FORM_ENDPOINT=

# Razorpay (server-side only — keep secret)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Razorpay public key for client SDK
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Email transport. Priority: Resend (RESEND_API_KEY) → Gmail SMTP (SMTP_*) → console log.
#
# Resend (preferred — required for bulk announcement sends; Gmail SMTP blocks bulk volume).
# Create a key at https://resend.com/api-keys and verify the microcharity.com domain
# (add the SPF/DKIM DNS records Resend shows you). The SMTP_FROM address below must be
# on the verified domain.
RESEND_API_KEY=
#
# Gmail SMTP — fallback for low-volume / local dev. Use a Gmail App Password
# (https://myaccount.google.com/apppasswords); requires 2-step verification.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Sender address (the display name is fixed in code as "MicroCharity.com"). Must be on
# the Resend-verified domain when using Resend.
SMTP_FROM="MicroCharity.com <info@microcharity.com>"
ADMIN_INBOX=info@microcharity.com

# Database (PostgreSQL)
DATABASE_URL=

# Admin auth
ADMIN_SESSION_SECRET=
